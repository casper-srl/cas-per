---
import BaseLayout from "../../layouts/BaseLayout.astro";

const monitorGalleries = [
  {
    title: "Monitor accoglienza",
    kicker: "Ingresso",
    text: "Schermi collocati nelle aree di accesso per orientare visitatori e familiari con annunci, orari e indicazioni.",
    images: [
      ["/assets/monitor-gallery/uploads/2020/03/ingresso2.jpg", "Monitor digitale in area accoglienza"],
      ["/assets/monitor-gallery/uploads/2020/03/ingresso3.jpg", "Monitor all'ingresso con annunci aggiornati"],
      ["/assets/monitor-gallery/uploads/2025/09/ingresso1.jpg", "Schermo informativo in ambiente di ingresso"],
    ],
  },
  {
    title: "Monitor stanza",
    kicker: "Stanze",
    text: "Display dedicati alle sale del commiato: nome, informazioni principali e dettagli utili sempre visibili.",
    images: [
      ["/assets/monitor-gallery/uploads/2020/03/stanza1-1.jpeg", "Monitor stanza con nome dedicato"],
      ["/assets/monitor-gallery/uploads/2020/03/stanza2-1.jpeg", "Monitor stanza con dati del servizio"],
      ["/assets/monitor-gallery/uploads/2025/09/monitor-stanza-santambrogio-con-dettagli.jpeg", "Monitor stanza con dettagli della cerimonia"],
    ],
  },
  {
    title: "Tablet cordogli",
    kicker: "Cordogli",
    text: "Postazioni discrete per raccogliere messaggi digitali e trasformarli in una memoria ordinata per la famiglia.",
    images: [
      ["/assets/monitor-gallery/uploads/2020/03/tablet3.jpeg", "Postazione tablet per cordogli online"],
      ["/assets/monitor-gallery/uploads/2025/09/tablet1.jpg", "Tablet cordogli in area dedicata"],
      ["/assets/monitor-gallery/uploads/2025/09/tablet2.jpg", "Esempio di tablet per raccolta messaggi"],
    ],
  },
  {
    title: "Monitor vetrina",
    kicker: "Vetrina",
    text: "Soluzioni visibili anche da sedi secondarie o spazi non presidiati, per mantenere comunicazioni aggiornate.",
    images: [
      ["/assets/monitor-gallery/uploads/2025/09/ingresso3.jpg", "Monitor vetrina con annunci e orari"],
      ["/assets/monitor-gallery/uploads/2020/03/ingresso3.jpg", "Schermo informativo vicino all'ingresso"],
    ],
  },
];
---

<BaseLayout
  title="Monitor per case funerarie e vetrine | Cas-Per"
  description="Soluzioni Cas-Per per monitor ingresso, monitor stanza, tablet cordogli e vetrine digitali nelle case funerarie."
>
  <section class="page-hero solution-hero">
    <div class="section-inner split visual-split">
      <div>
        <p class="eyebrow">Monitor e case funerarie</p>
        <h1>Comunicazioni aggiornate, eleganti e gestibili da remoto.</h1>
        <p class="lead">
          Trasforma monitor già presenti o scelti liberamente sul mercato in strumenti digitali per ingressi, stanze,
          vetrine e aree di servizio.
        </p>
        <div class="hero-actions">
          <a class="button primary" href="https://wa.me/393408384217">Richiedi informazioni</a>
          <a class="button secondary" href="/soluzioni/">Tutte le soluzioni</a>
        </div>
      </div>
      <div class="asset-panel service-visual monitor-visual" aria-label="Sistema monitor per case funerarie">
        <div class="monitor-wall">
          <div class="monitor-screen">
            <span class="monitor-label">Sala del Commiato</span>
            <strong>Mario Rossi</strong>
            <small>Visite 9:00 - 18:00</small>
            <div class="monitor-lines"><span></span><span></span><span></span></div>
          </div>
          <div class="monitor-stand"></div>
        </div>
        <div class="monitor-side monitor-window">
          <span>Vetrina</span>
          <strong>Annunci aggiornati</strong>
        </div>
        <div class="monitor-side monitor-tablet">
          <span>Tablet</span>
          <strong>Cordogli</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner editorial-grid">
      <aside class="section-index">02</aside>
      <div>
        <p class="eyebrow">L'innovazione sposa la tradizione</p>
        <h2>Non vendiamo monitor: costruiamo una regia digitale per i tuoi spazi.</h2>
      </div>
      <div class="rich-text teal-card">
        <p>
          Il sistema si basa su piccoli dispositivi già configurati con il software Cas-Per. Si collegano al retro di un
          monitor con HDMI e USB: lo schermo diventa subito pronto a mostrare annunci, necrologi e informazioni in tempo
          reale.
        </p>
        <p>
          Puoi usare monitor già presenti, sceglierne di nuovi senza vincoli o estendere l'impianto gradualmente. La
          gestione avviene da remoto, da qualsiasi dispositivo con accesso a internet.
        </p>
      </div>
    </div>
  </section>

  <section class="section muted">
    <div class="section-inner">
      <div class="section-heading">
        <p class="eyebrow">Applicazioni</p>
        <h2>Ogni schermo ha un compito preciso.</h2>
      </div>
      <div class="detail-grid">
        <article class="teal-card">
          <span class="detail-kicker">Ingresso</span>
          <h3>Monitor accoglienza</h3>
          <p>Orari, cerimonie, avvisi e indicazioni pratiche per orientare chi entra nella casa funeraria.</p>
        </article>
        <article class="teal-card">
          <span class="detail-kicker">Stanze</span>
          <h3>Monitor stanza</h3>
          <p>Nome del defunto, orari di visita e comunicazioni dedicate a familiari e ospiti.</p>
        </article>
        <article class="teal-card">
          <span class="detail-kicker">Cordogli</span>
          <h3>Tablet cordogli</h3>
          <p>Un dispositivo discreto per lasciare pensieri digitali, poi raccolti e consegnabili alla famiglia.</p>
        </article>
        <article class="teal-card">
          <span class="detail-kicker">Vetrina</span>
          <h3>Monitor vetrina</h3>
          <p>Annunci, iniziative e informazioni dell'impresa visibili anche in sedi secondarie o luoghi presidiati.</p>
        </article>
      </div>

      <div class="monitor-gallery-stack">
        {monitorGalleries.map((gallery) => (
          <article class="monitor-gallery-card">
            <div class="monitor-gallery-copy">
              <span class="detail-kicker">{gallery.kicker}</span>
              <h3>{gallery.title}</h3>
              <p>{gallery.text}</p>
            </div>
            <div class="monitor-gallery-images">
              {gallery.images.map(([src, alt]) => (
                <figure>
                  <img src={src} alt={alt} loading="lazy" />
                </figure>
              ))}
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner brochure-showcase">
      <div>
        <p class="eyebrow">Brochure</p>
        <h2>Il digitale per le case funerarie, raccolto in una guida rapida.</h2>
        <p class="lead small-lead">
          Una panoramica dei monitor per ingresso, stanze e vetrine, con esempi d'uso e possibilità di integrazione
          negli spazi dell'impresa.
        </p>
        <div class="hero-actions">
          <a class="button primary" href="/assets/cas-per-news-digitale-case-funerarie.pdf" target="_blank" rel="noopener">
            Apri la brochure
          </a>
          <a class="button secondary" href="https://wa.me/393408384217">Contattaci</a>
        </div>
      </div>
      <div
        class="brochure-card flipbook-card"
        data-brochure-viewer
        data-pdf-src="/assets/cas-per-news-digitale-case-funerarie.pdf"
        aria-label="Brochure sfogliabile Il digitale per le case funerarie"
      >
        <iframe
          data-brochure-frame
          src="/assets/cas-per-news-digitale-case-funerarie.pdf?view=1#page=1&zoom=page-fit&toolbar=0&navpanes=0&scrollbar=0"
          title="Brochure Il digitale per le case funerarie"
          loading="lazy"
        ></iframe>
        <div class="brochure-controls" aria-label="Controlli brochure">
          <button type="button" data-brochure-prev aria-label="Pagina precedente">&lt;</button>
          <span><strong data-brochure-current>1</strong> / 28</span>
          <button type="button" data-brochure-next aria-label="Pagina successiva">&gt;</button>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner split">
      <div>
        <p class="eyebrow">Perché sceglierlo</p>
        <h2>Una soluzione scalabile, stabile e coerente con AnnunciFunebri.it.</h2>
      </div>
      <div class="rich-text">
        <p>
          I contenuti possono arrivare dalla piattaforma AnnunciFunebri.it o dai sistemi collegati. Gli aggiornamenti
          sono centralizzati e non richiedono interventi sui singoli schermi.
        </p>
        <p>
          È un modo moderno per informare visitatori, organizzare il lavoro interno e mantenere una presenza curata negli
          spazi fisici dell'impresa.
        </p>
        <a class="button primary" href="https://wa.me/393408384217">Rendi digitale la tua casa funeraria</a>
      </div>
    </div>
  </section>

  <script>
    const brochureViewer = document.querySelector("[data-brochure-viewer]");

    if (brochureViewer) {
      const totalPages = 28;
      const pdfSrc = brochureViewer.getAttribute("data-pdf-src");
      const frame = brochureViewer.querySelector("[data-brochure-frame]");
      const current = brochureViewer.querySelector("[data-brochure-current]");
      const previous = brochureViewer.querySelector("[data-brochure-prev]");
      const next = brochureViewer.querySelector("[data-brochure-next]");
      let page = 1;

      const updateBrochure = () => {
        current.textContent = String(page);
        previous.disabled = page === 1;
        next.disabled = page === totalPages;
        frame.src = `${pdfSrc}?view=${page}#page=${page}&zoom=page-fit&toolbar=0&navpanes=0&scrollbar=0`;
      };

      previous.addEventListener("click", () => {
        page = Math.max(1, page - 1);
        updateBrochure();
      });

      next.addEventListener("click", () => {
        page = Math.min(totalPages, page + 1);
        updateBrochure();
      });

      updateBrochure();
    }
  </script>
  <script is:inline>
    (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "v0ukd0ppt6");
  </script>
</BaseLayout>
