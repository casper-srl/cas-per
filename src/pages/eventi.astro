---
import BaseLayout from "../layouts/BaseLayout.astro";

const pastEditions = [
  { name: "Nimis 2021", img: "/assets/nimis-21.jpg", url: "https://www.rip-party.it/nimis-2021" },
  { name: "Fossombrone 2024", img: "/assets/fossombrone-2024.webp", url: "https://www.rip-party.it/fossombrone-2024" },
  { name: "Sorbara 2024", img: "/assets/sorbara-2024.webp", url: "https://www.rip-party.it/sorbara-2024" },
  { name: "Nimis 2024", img: "/assets/nimis-24.jpg", url: "https://www.rip-party.it/nimis-2024" },
  { name: "Caramagna 2024", img: "/assets/caramagna-2024.webp", url: "https://www.rip-party.it/caramagna-2024" },
  { name: "Franciacorta 2026", img: "/assets/franciacorta-2026.webp", url: "https://www.rip-party.it/franciacorta-2026" },
  { name: "Puglia 2026", img: "/assets/puglia-2026.jpg", url: "https://www.rip-party.it/puglia-2026" }
];
---

<BaseLayout title="Eventi e partnership | Cas-Per">
  <div class="glass-bg-blobs" aria-hidden="true">
    <div class="blob-circle blob-cyan" style="top: 10%; right: 10%; width: 400px; height: 400px; opacity: 0.15;"></div>
    <div class="blob-circle blob-mauve" style="top: 40%; left: 5%; width: 320px; height: 320px; opacity: 0.12;"></div>
  </div>

  <section class="page-hero rip-party-hero">
    <div class="section-inner rip-hero-grid">
      <div>
        <p class="eyebrow">Eventi</p>
        <h1>Rip-Party: incontrarsi, conoscersi, costruire relazioni.</h1>
        <p class="lead">Serate informali con partner del settore, pensate per creare contatti veri e rafforzare il rapporto con imprese e professionisti.</p>
        <a href="https://www.rip-party.it/" target="_blank" class="button primary" style="margin-top: 24px;">scopri di più</a>
      </div>
      <div class="rip-hero-statue" aria-hidden="true">
        <img src="/assets/rip-party-statue-cutout.png?v=2" alt="" />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner split-three">
      <div class="event-card teal-card">
        <p class="eyebrow">Prossimo appuntamento</p>
        <h2>Veneto</h2>
        <p class="event-date" style="color: var(--teal-deep); font-weight: 700; margin-top: 10px;">30 luglio 2026</p>
        <a class="button primary" href="https://www.rip-party.it/" target="_blank" style="margin-top: 20px;">Iscriviti all'evento</a>
      </div>
      <div class="rich-text" style="display: flex; flex-direction: column; justify-content: center;">
        <p>
          Rip-Party nasce nel 2021 insieme a partner del settore. Ogni serata viene organizzata in cantine o strutture
          ricettive di spessore, creando un contesto naturale per parlare, ascoltare e conoscere nuove imprese.
        </p>
        <p>
          Non è solo un evento: è un modo concreto per mostrare una Cas-Per presente, dinamica e vicina al mercato, favorendo relazioni spontanee al di fuori delle dinamiche commerciali classiche.
        </p>
      </div>
      <figure class="event-photo-wrap">
        <img src="/assets/rip-party-staff.jpg" alt="Staff e partner durante una serata Rip-Party" />
        <figcaption>Staff e partner Rip-Party</figcaption>
      </figure>
    </div>
  </section>

  <!-- Sezione Rivivi le edizioni passate (Armonizzata con lo stile del sito) -->
  <section class="section">
    <div class="section-inner">
      <h2 class="section-title">rivivi le edizioni passate</h2>
      
      <div class="editions-grid">
        {pastEditions.map(edition => (
          <a href={edition.url} target="_blank" class="past-edition-card">
            <div class="lens-frame">
              <img src={edition.img} alt={edition.name} />
            </div>
            <span class="lens-label">{edition.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Sezione Partner (da Screenshot) -->
  <section class="section muted">
    <div class="section-inner" style="display: flex; flex-direction: column; align-items: center; text-align: center;">
      <h2 class="partners-title">
        la rete che ti libera
        <strong>da ogni pensiero.</strong>
      </h2>
      
      <div class="partners-grid-wrap">
        <div class="partners-row">
          <a href="http://www.annuncifunebri.it/" target="_blank" class="partner-link">
            <img src="/assets/partners/logo-af.png" alt="Annunci Funebri" />
          </a>
          <a href="http://www.onoranzefunebricloud.com/" target="_blank" class="partner-link">
            <img src="/assets/partners/logo-ofc.png" alt="OFC" />
          </a>
          <a href="http://www.giesse.info/" target="_blank" class="partner-link">
            <img src="/assets/partners/logo-giesse.png" alt="Giesse" />
          </a>
          <a href="http://www.blsrl.net/" target="_blank" class="partner-link">
            <img src="/assets/partners/logo-bl.png" alt="BL" />
          </a>
        </div>
        
        <div class="partners-row">
          <a href="http://www.urciuoli.net/" target="_blank" class="partner-link">
            <img src="/assets/partners/logo-urciuoli.png" alt="Urciuoli" />
          </a>
          <a href="https://www.pilla.com/" target="_blank" class="partner-link">
            <img src="/assets/partners/logo-pilla.png" alt="Pilla" />
          </a>
          <a href="https://www.ferraricofani.it/" target="_blank" class="partner-link">
            <img src="/assets/partners/logo-ferrari.png" alt="Ferrari" />
          </a>
          <a href="https://www.menegardocofanifunebri.it/" target="_blank" class="partner-link">
            <img src="/assets/partners/logo-menegardo.png" alt="Menegardo" />
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .rip-party-hero {
    overflow: hidden;
  }

  .rip-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(220px, 360px);
    gap: clamp(28px, 5vw, 72px);
    align-items: center;
  }

  .rip-hero-statue {
    position: relative;
    display: grid;
    align-self: end;
    min-height: 430px;
    place-items: end center;
    margin-bottom: calc(clamp(56px, 8vw, 96px) * -1);
  }

  .rip-hero-statue::before {
    content: "";
    position: absolute;
    inset: 10% 0 0;
    border-radius: 50%;
    background:
      radial-gradient(circle at 45% 35%, rgba(5, 162, 194, 0.28), transparent 58%),
      radial-gradient(circle at 65% 60%, rgba(226, 180, 189, 0.28), transparent 62%);
    filter: blur(8px);
  }

  .rip-hero-statue img {
    position: relative;
    z-index: 1;
    width: min(120%, 430px);
    max-height: 470px;
    object-fit: contain;
    filter: drop-shadow(0 26px 34px rgba(23, 43, 49, 0.16));
    transform: rotate(2deg);
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    text-align: center;
    margin-bottom: 50px;
    font-weight: 300;
    letter-spacing: -0.02em;
    color: var(--teal-deep);
    text-transform: lowercase;
  }

  .editions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 40px 30px;
    max-width: 1000px;
    margin: 0 auto;
    justify-items: center;
  }

  .past-edition-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .past-edition-card:hover {
    transform: translateY(-6px);
  }

  .lens-frame {
    position: relative;
    width: 150px;
    height: 150px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--glass-bg);
    border: 2px solid var(--glass-border);
    box-shadow: var(--glass-shadow);
    margin-bottom: 16px;
    padding: 6px;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .lens-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    transition: transform 0.3s ease;
  }

  .past-edition-card:hover .lens-frame {
    background: var(--glass-bg-hover);
    border-color: var(--teal);
    box-shadow: -10px -10px 20px 0px #ffffff, 10px 10px 20px 0px rgba(13, 39, 80, 0.12);
  }

  .past-edition-card:hover .lens-frame img {
    transform: scale(1.08);
  }

  .lens-label {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--soft-ink);
    text-align: center;
    transition: color 0.2s ease;
  }

  .past-edition-card:hover .lens-label {
    color: var(--teal-deep);
  }

  .split-three {
    display: grid;
    grid-template-columns: 320px minmax(0, 0.86fr) minmax(360px, 1fr);
    gap: 40px;
    align-items: stretch;
  }

  .event-photo-wrap {
    position: relative;
    display: grid;
    align-content: end;
    background: var(--glass-bg);
    border: 1px solid var(--glass-border);
    border-left: 5px solid var(--teal);
    border-radius: var(--radius);
    box-shadow: var(--glass-shadow);
    padding: 12px;
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    overflow: hidden;
    min-height: 300px;
    margin: 0;
  }

  .event-photo-wrap img {
    width: 100%;
    height: 260px;
    object-fit: cover;
    object-position: center;
    border-radius: 8px;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .event-photo-wrap:hover img {
    transform: scale(1.035);
  }

  .event-photo-wrap figcaption {
    padding: 14px 4px 4px;
    color: var(--teal-deep);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  /* Partners Section Styling */
  .partners-title {
    font-size: clamp(1.8rem, 3.8vw, 2.6rem);
    line-height: 1.25;
    margin-bottom: 50px;
    font-weight: 300;
    letter-spacing: -0.01em;
    color: var(--teal-deep);
    text-transform: lowercase;
    font-style: italic;
  }

  .partners-title strong {
    display: block;
    font-size: clamp(1.5rem, 3.2vw, 2.2rem);
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ink);
    font-style: normal;
    margin-top: 6px;
  }

  .partners-grid-wrap {
    display: grid;
    gap: 36px;
    max-width: 900px;
    width: 100%;
  }

  .partners-row {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 32px 48px;
  }

  .partner-link {
    display: block;
    width: 140px;
    opacity: 0.65;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .partner-link img {
    width: 100%;
    height: 64px;
    object-fit: contain;
    filter: grayscale(100%);
    transition: all 0.3s ease;
  }

  .partner-link:hover {
    opacity: 1;
    transform: translateY(-2px);
  }

  .partner-link:hover img {
    filter: grayscale(0%);
  }

  @media (max-width: 1024px) {
    .rip-hero-grid {
      grid-template-columns: 1fr;
    }

    .rip-hero-statue {
      min-height: 300px;
      margin-bottom: -56px;
      place-items: center;
    }

    .rip-hero-statue img {
      width: min(86vw, 340px);
      max-height: 350px;
    }

    .split-three {
      grid-template-columns: 1fr;
      gap: 30px;
    }
    .event-photo-wrap {
      width: min(100%, 560px);
      margin: 0 auto;
    }
  }

  @media (max-width: 768px) {
    .editions-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 30px 20px;
    }
    .lens-frame {
      width: 130px;
      height: 130px;
      padding: 4px;
    }
    .partner-link {
      width: 110px;
    }
    .partner-link img {
      height: 48px;
    }
    .partners-row {
      gap: 24px;
    }
  }
</style>
