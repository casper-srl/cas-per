---
const { target, label = "pagina aggiornata" } = Astro.props;
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Pagina spostata | Cas-Per</title>
    <style>
      body {
        min-height: 100vh;
        margin: 0;
        display: grid;
        place-items: center;
        font-family: "Century Gothic", "CenturyGothic", "AppleGothic", sans-serif;
        color: #1a1a1a;
        background:
          radial-gradient(circle at 70% 20%, rgba(5, 162, 194, 0.12), transparent 34%),
          #fff;
      }

      main {
        width: min(520px, calc(100% - 40px));
        padding: 40px;
        border-left: 5px solid #05a2c2;
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.72);
        box-shadow: 0 24px 60px rgba(23, 43, 49, 0.08);
      }

      p {
        margin: 0 0 20px;
        line-height: 1.6;
      }

      a {
        color: #007f98;
        font-weight: 700;
      }
    </style>
  </head>
  <body>
    <main>
      <p>Questa sezione e stata spostata nella nuova {label}.</p>
      <a href={target}>Vai alla pagina corretta</a>
    </main>
    <script define:vars={{ target }}>
      window.location.replace(target);
    </script>
  </body>
</html>
